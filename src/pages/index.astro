---
import Base from "../layouts/Base.astro";

const experience = [
  {
    role: "Technical lead",
    org: "Generate",
    orgUrl: "https://generatenu.com",
    dates: "July 2023 – 2024",
    description:
      "Led a team of six building a cross-platform mobile app in React Native and Go that personalizes end-of-life planning.",
  },
  {
    role: "Software engineering intern, machine learning",
    org: "Genentech",
    orgUrl: "https://www.gene.com",
    dates: "January – June 2023",
    description:
      "Built a drug-data structuring system with transformer models and rule-based matching to normalize unstructured text across gRED, hitting 93% accuracy.",
  },
  {
    role: "Teaching assistant",
    org: "Khoury College of Computer Sciences",
    orgUrl: "https://www.khoury.northeastern.edu",
    dates: "Fall 2022",
    description:
      "Ran 4+ hours of weekly office hours and assisted faculty with grading and feedback.",
  },
];

const projects = [
  {
    name: "brain-kit",
    url: "https://github.com/DOOduneye/brain-kit",
    description:
      "A knowledge-base workflow for Claude Code — a CLI, vault skeleton, and skills for developing out of a personal knowledge base.",
  },
  {
    name: "monkey",
    url: "https://github.com/DOOduneye/monkey",
    description:
      "An interpreter and compiler for the Monkey language, written in Go while working through Thorsten Ball's books.",
  },
  {
    name: "hydrate",
    url: "https://github.com/DOOduneye/hydrate",
    description: "A token-based authentication utility for Go.",
  },
  {
    name: "Jurni",
    url: null,
    description:
      "NLP over 50,000+ journal entries for a mental health service — sentiment analysis and topic modeling to surface trigger points for clinicians.",
  },
  {
    name: "RateMyDorm",
    url: "https://github.com/DOOduneye/rmd",
    description:
      "A full-stack Next.js app where students rate and compare campus dorms, backed by the College Scorecard API.",
  },
  {
    name: "davidoduneye.com",
    url: "https://github.com/DOOduneye/portfolio",
    description:
      "This site. Astro, markdown, and GitHub Pages — static, fast, no fluff.",
  },
];
---

<Base title="David Oduneye">
  <section class="prose">
    <h1>David Oduneye</h1>
    <p style="margin-top: 0.75rem;">
      Software engineer out of Boston — computer science at Northeastern
      University. This is what I've built and where I've worked.
    </p>
  </section>

  <section>
    <h2 class="section-label">Experience</h2>
    <ul class="entry-list">
      {
        experience.map((job) => (
          <li class="entry">
            <h3>
              {job.role} ·{" "}
              <a href={job.orgUrl} target="_blank" rel="noopener noreferrer">
                {job.org}
              </a>
            </h3>
            <span class="meta">{job.dates}</span>
            <p>{job.description}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <section>
    <h2 class="section-label">Projects</h2>
    <ul class="entry-list">
      {
        projects.map((project) => (
          <li class="entry">
            <h3>
              {project.url ? (
                <a href={project.url} target="_blank" rel="noopener noreferrer">
                  {project.name}
                </a>
              ) : (
                project.name
              )}
            </h3>
            <p>{project.description}</p>
          </li>
        ))
      }
    </ul>
  </section>
</Base>
