{
  "name": "davidoduneye.com",
  "version": "3.0.0",
  "private": true,
  "packageManager": "pnpm@11.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check": "tsc --noEmit",
    "build": "tsc --noEmit && vite build && cp dist/client/index.html dist/client/404.html",
    "preview": "vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply portfolio-cms --local",
    "db:migrate": "wrangler d1 migrations apply portfolio-cms --remote"
  },
  "dependencies": {
    "@tiptap/react": "^3.0.0",
    "@tiptap/starter-kit": "^3.0.0",
    "@trpc/client": "^11.0.2",
    "@trpc/server": "^11.0.2",
    "drizzle-orm": "^0.44.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.43.0",
    "@cloudflare/workers-types": "^4.20250101.0",
    "@tailwindcss/vite": "^4.1.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  }
}
