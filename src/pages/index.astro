---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";

const posts = (await getCollection("writing"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });

const projects = [
  {
    name: "brain-kit",
    url: "https://github.com/DOOduneye/brain-kit",
    description:
      "A knowledge-base workflow for Claude Code — a CLI, vault skeleton, and skills for developing out of a personal knowledge base.",
  },
  {
    name: "monkey",
    url: "https://github.com/DOOduneye/monkey",
    description:
      "An interpreter and compiler for the Monkey language, written in Go while working through Thorsten Ball's books.",
  },
  {
    name: "hydrate",
    url: "https://github.com/DOOduneye/hydrate",
    description: "A token-based authentication utility for Go.",
  },
  {
    name: "davidoduneye.com",
    url: "https://github.com/DOOduneye/portfolio",
    description:
      "This site. Astro, markdown, and GitHub Pages — static, fast, no fluff.",
  },
];
---

<Base title="David Oduneye">
  <section>
    <h1>David Oduneye</h1>
    <p style="margin-top: 0.75rem; color: var(--color-text-secondary);">
      Software engineer. I think about types, systems, and building software
      that's safe to change.
    </p>
  </section>

  <section>
    <h2 class="section-label">Latest writing</h2>
    <ul class="entry-list">
      {
        posts.map((post) => (
          <li class="entry">
            <h3>
              <a href={`/writing/${post.id}/`}>{post.data.title}</a>
            </h3>
            <span class="meta">{formatDate(post.data.pubDate)}</span>
            <p>{post.data.description}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <section>
    <h2 class="section-label">Selected projects</h2>
    <ul class="entry-list">
      {
        projects.map((project) => (
          <li class="entry">
            <h3>
              <a href={project.url} target="_blank" rel="noopener noreferrer">
                {project.name}
              </a>
            </h3>
            <p>{project.description}</p>
          </li>
        ))
      }
    </ul>
  </section>
</Base>
