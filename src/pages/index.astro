---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";

const posts = (await getCollection("writing"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });

const projects = [
  {
    name: "brain-kit",
    url: "https://github.com/DOOduneye/brain-kit",
    description:
      "A knowledge-base workflow for Claude Code — a CLI, vault skeleton, and skills for developing out of a personal knowledge base.",
  },
  {
    name: "monkey",
    url: "https://github.com/DOOduneye/monkey",
    description:
      "An interpreter and compiler for the Monkey language, written in Go while working through Thorsten Ball's books.",
  },
  {
    name: "hydrate",
    url: "https://github.com/DOOduneye/hydrate",
    description: "A token-based authentication utility for Go.",
  },
  {
    name: "davidoduneye.com",
    url: "https://github.com/DOOduneye/portfolio",
    description:
      "This site. Astro, markdown, and GitHub Pages — static, fast, no fluff.",
  },
];
---

<Base title="David Oduneye">
  <section class="prose">
    <h1>I'm David.</h1>
    <p style="margin-top: 1rem;">
      I'm a software engineer in Boston. I build software that's safe to
      change, compete as a
      <a
        href="https://www.openpowerlifting.org/u/davidoduneye"
        target="_blank"
        rel="noopener noreferrer">powerlifter</a
      >, and carry a camera more places than I strictly need to.
    </p>
    <p>
      This site is where I keep the things I make and think about — essays on
      building software, projects I care about, and whatever else earns a
      page. If you want the fuller story, start with the
      <a href="/about">about page</a>.
    </p>
  </section>

  <section>
    <h2 class="section-label">What I've been writing</h2>
    <ul class="entry-list">
      {
        posts.map((post) => (
          <li class="entry">
            <h3>
              <a href={`/writing/${post.id}/`}>{post.data.title}</a>
            </h3>
            <span class="meta">{formatDate(post.data.pubDate)}</span>
            <p>{post.data.description}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <section>
    <h2 class="section-label">What I've been building</h2>
    <ul class="entry-list">
      {
        projects.map((project) => (
          <li class="entry">
            <h3>
              <a href={project.url} target="_blank" rel="noopener noreferrer">
                {project.name}
              </a>
            </h3>
            <p>{project.description}</p>
          </li>
        ))
      }
    </ul>
  </section>
</Base>
